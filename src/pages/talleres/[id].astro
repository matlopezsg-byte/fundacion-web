---
import Layout from '../../layouts/Layout.astro';
import talleresData from '../../data/talleres.json';

export function getStaticPaths() {
  return talleresData.talleres.map((taller) => ({
    params: { id: taller.id },
    props: { taller },
  }));
}

const { taller } = Astro.props;
---

<Layout title={taller.titulo}>
  <section class="taller-detalle">
    <div class="taller-container">
      <a href="/#talleres" class="volver">← Volver</a>
      <span class="taller-ubicacion"><svg class="icon-ubicacion" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#E53935" width="18" height="18"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg> {taller.ubicacion}</span>
      <h1 class="taller-titulo">{taller.titulo}</h1>
      <div class="taller-img">
        <img src={taller.imagen} alt={taller.titulo} />
      </div>
      <div class="taller-contenido">
        {taller.contenido.split('\n\n').map((parrafo) => (
          <p>{parrafo}</p>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .taller-detalle {
    margin-top: var(--header-height);
    padding: 3rem 0;
  }

  .taller-container {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .volver {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .volver:hover {
    color: var(--color-primary-dark);
  }

  .taller-ubicacion {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.95rem;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .taller-ubicacion :global(.icon-ubicacion) {
    flex-shrink: 0;
  }

  .taller-titulo {
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
    text-transform: none;
  }

  .taller-img {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .taller-img img {
    width: 100%;
    height: 350px;
    object-fit: cover;
  }

  .taller-contenido p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .taller-titulo {
      font-size: 1.4rem;
    }

    .taller-img img {
      height: 220px;
    }
  }
</style>
